{
  "name": "TestSuite",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the test suite"
    },
    "description": {
      "type": "string",
      "description": "Optional description"
    },
    "scriptIds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Ordered list of script IDs to run"
    }
  },
  "required": [
    "name",
    "scriptIds"
  ]
}